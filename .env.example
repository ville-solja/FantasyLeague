# GitHub repository in owner/repo format (e.g. myusername/dota-kanaliiga-fantasy)
# Used to pull the correct image from ghcr.io
GITHUB_REPOSITORY=your-username/dota-kanaliiga-fantasy

# Google Sheets CSV export URL for the season fixture list (sheet must be publicly viewable)
# File > Share > Publish to web > CSV, or use: spreadsheets/d/{ID}/export?format=csv
SCHEDULE_SHEET_URL=https://docs.google.com/spreadsheets/d/13rcLiJ99tQqdKMKIC7qs7ISqCZIZHoiz6XXLdv4rLlM/export?format=csv

# Optional. Comma-separated Dotabuff league *overview* page URLs to scrape for team icons
# (saved under assets/.../dotabuff_league_logos/; skipped if file already exists).
# Omit variable for Kanaliiga S15 defaults; set empty to disable: DOTABUFF_LEAGUE_LOGO_PAGES=
# DOTABUFF_LEAGUE_LOGO_PAGES=https://www.dotabuff.com/esports/leagues/19368-kanaliiga-season-15,https://www.dotabuff.com/esports/leagues/19369-kanaliiga-season-15-lower

# Comma-separated OpenDota league IDs to ingest automatically on startup.
# Skips matches already in the database, so restarts are fast.
# Set to empty to disable: AUTO_INGEST_LEAGUES=
AUTO_INGEST_LEAGUES=19368,19369

# Optional. Raises OpenDota rate limits so player/team enrichment (names, avatars, logos) can finish.
# Get a key at https://www.opendota.com/api-keys
# OPENDOTA_API_KEY=

# Max OpenDota API requests per rolling 60s (free tier ~60/min; default 55 for headroom).
# OPENDOTA_MAX_RPM=55

# ISO date of the first Sunday lock (YYYY-MM-DD). All weekly period boundaries
# are derived from this anchor. Update for a new season and reset the database.
SEASON_LOCK_START=2026-03-08

# Display name for the in-game token currency (shown in the UI).
TOKEN_NAME=Kana Tokens

# Number of tokens granted automatically on new user registration.
INITIAL_TOKENS=5

# SMTP settings for outgoing email (used for forgot-password temporary passwords).
# Leave SMTP_HOST unset to disable email sending (password resets will be logged but not sent).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=yourpassword
# SMTP_FROM=noreply@example.com
# SMTP_TLS=true

# Display name used in outgoing emails (subject line prefix).
APP_NAME=Kanaliiga Fantasy

# Twitch Extension (EBS) settings.
# Required for the Twitch panel extension (MVP selection, token drops, giveaway).
# Get these from https://dev.twitch.tv/console/extensions after registering an extension.
# TWITCH_EXTENSION_CLIENT_ID=your_client_id_here
# TWITCH_EXTENSION_SECRET=base64_encoded_secret_from_twitch_console
# TWITCH_DROP_MAX=20

# Optional. Twitch bot account credentials for posting MVP/drop results to chat.
# Requires a user access token with the user:write:chat scope and the bot's Twitch user ID.
# If unset, chat messages are silently skipped (extension PubSub broadcast still fires).
# TWITCH_BOT_ACCESS_TOKEN=your_oauth_token_here
# TWITCH_BOT_USER_ID=123456789

# Set to "true" to skip Twitch JWT validation for local development.
# The EBS will accept any Authorization header and behave as a broadcaster.
# NEVER set this in production.
# TWITCH_LOCAL_DEV=true

# Security. Must be set in production — app refuses to start without it unless DEBUG=true.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=change-me-in-production

# Set to "true" to enable DEBUG mode (bypasses SECRET_KEY requirement for local dev).
# NEVER set in production.
# DEBUG=true

# Set to "true" if the app is behind an HTTPS reverse proxy (e.g. nginx/caddy).
# Enables the Secure flag on session cookies. Defaults to false.
# HTTPS_ONLY=true

# Maximum active cards per user roster. Default: 5.
# ROSTER_LIMIT=5

# JSON object of scoring weight overrides applied on startup.
# Keys not present fall back to hardcoded defaults (see backend/seed.py).
# Example: WEIGHTS_JSON={"kills": 4.0, "deaths": -1.5}
# WEIGHTS_JSON=

# Seconds between ingest poll cycles (fetches new matches + syncs Toornament). Default: 900 (15 min).
# INGEST_POLL_INTERVAL=900

# Seconds between week generation and auto-lock maintenance checks. Default: 300 (5 min).
# WEEK_CHECK_INTERVAL=300

# Anthropic API key for AI-generated player bios (player profile enrichment feature).
# If unset, enrichment stores facts but skips bio generation.
# ANTHROPIC_API_KEY=

# Minimum hours between re-enrichment for a given player. Default: 24.
# PROFILE_ENRICHMENT_COOLDOWN_HOURS=24

# Seconds between profile enrichment background cycles. Default: 300 (5 min).
# ENRICHMENT_CHECK_INTERVAL=300

# Players enriched per cycle (limits OpenDota API calls per batch). Default: 3.
# ENRICHMENT_BATCH_SIZE=3

# Toornament integration (optional). Pushes series results to toornament.com.
# Get credentials at https://developer.toornament.com after registering an application.
# TOORNAMENT_CLIENT_ID=your_client_id
# TOORNAMENT_CLIENT_SECRET=your_client_secret
# TOORNAMENT_API_KEY=your_api_key
# TOORNAMENT_TOURNAMENT_ID=your_tournament_id

# Build version displayed faintly on every page (set by CI to the image SHA).
# APP_VERSION=
# Release tag displayed alongside APP_VERSION in production (e.g. v1.2.0).
# APP_RELEASE=
