# GitHub repository in owner/repo format (e.g. myusername/dota-kanaliiga-fantasy)
# Used to pull the correct image from ghcr.io
GITHUB_REPOSITORY=your-username/dota-kanaliiga-fantasy

# Google Sheets CSV export URL for the season fixture list (sheet must be publicly viewable)
# File > Share > Publish to web > CSV, or use: spreadsheets/d/{ID}/export?format=csv
SCHEDULE_SHEET_URL=https://docs.google.com/spreadsheets/d/13rcLiJ99tQqdKMKIC7qs7ISqCZIZHoiz6XXLdv4rLlM/export?format=csv

# Comma-separated OpenDota league IDs to ingest automatically on startup.
# Skips matches already in the database, so restarts are fast.
# Set to empty to disable: AUTO_INGEST_LEAGUES=
AUTO_INGEST_LEAGUES=19368,19369

# ISO date of the first Sunday lock (YYYY-MM-DD). All weekly period boundaries
# are derived from this anchor. Update for a new season and reset the database.
SEASON_LOCK_START=2026-03-08

# Display name for the in-game token currency (shown in the UI).
TOKEN_NAME=Kana Tokens

# Number of tokens granted automatically on new user registration.
INITIAL_TOKENS=5

# SMTP settings for outgoing email (used for forgot-password temporary passwords).
# Leave SMTP_HOST unset to disable email sending (password resets will be logged but not sent).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=yourpassword
# SMTP_FROM=noreply@example.com
# SMTP_TLS=true

# Display name used in outgoing emails (subject line prefix).
# APP_NAME=Kanaliiga Fantasy
